OPENAI_API_KEY=your-openai-api-key
WHATSAPP_TOKEN=your-whatsapp-token
PHONE_NUMBER_ID=your-phone-number-id
META_VERIFY_TOKEN=your-meta-verify-token
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/fitness

# LLM configuration
LLM_PROVIDER=openai
OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/openai/v1/
LLM_MODEL=gpt-4.1

# Traefik / Let's Encrypt
DOMAIN=your-domain.example.com
ACME_EMAIL=your-email@example.com

# Set to "true" only for local testing / CI to skip real OpenAI and PGVector calls
# MOCK_AGENT=true
